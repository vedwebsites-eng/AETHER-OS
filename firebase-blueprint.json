{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A productivity task in the system",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["health", "learning", "creative", "work", "personal", "routine"] },
        "estimate": { "type": "integer" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "customXP": { "type": "integer" },
        "isChallenging": { "type": "boolean" },
        "isSpeedRun": { "type": "boolean" },
        "scheduledStart": { "type": "string", "format": "date-time" },
        "scheduledEnd": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "adherenceStatus": { "type": "string", "enum": ["ontime", "late", "partial", "missed"] }
      },
      "required": ["userId", "title", "createdAt", "status"]
    },
    "UserStats": {
      "title": "UserStats",
      "description": "Gamification statistics for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "level": { "type": "integer" },
        "experience": { "type": "integer" },
        "coins": { "type": "integer" },
        "unlockedFeatures": { "type": "array" },
        "totalTasksCompleted": { "type": "integer" },
        "currentStreak": { "type": "integer" },
        "lastActiveDate": { "type": "string", "format": "date-time" },
        "difficultyLevel": { "type": "string", "enum": ["easy", "normal", "hard"] },
        "unlockedAchievements": { "type": "array" },
        "unlockedItems": { "type": "array" },
        "totalWordsWritten": { "type": "integer" },
        "journalStreak": { "type": "integer" },
        "lastJournalDate": { "type": "string" },
        "reflectionPromptsAnswered": { "type": "integer" },
        "scheduleMasteryLevel": { "type": "integer" },
        "scheduledTasksCount": { "type": "integer" },
        "punctualStreak": { "type": "integer" },
        "pomodoroSessions": { "type": "integer" },
        "pomodoroToday": { "type": "integer" },
        "dailyBriefing": { "type": "object" },
        "dailyChallenge": { "type": "object" },
        "unlockedPerks": { "type": "array" },
        "activityLog": { "type": "array" },
        "streakHistory": { "type": "array" },
        "adherenceHistory": { "type": "array" },
        "lifeSync": { "type": "object" }
      },
      "required": ["userId", "level", "experience"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "Application settings for a user",
      "type": "object",
      "properties": {
        "difficultyMultiplier": { "type": "number" },
        "goalTargets": { "type": "object" },
        "ui": { "type": "object" },
        "display": { "type": "object" },
        "notifications": { "type": "object" },
        "aiRoutine": { "type": "array" }
      },
      "required": ["difficultyMultiplier", "goalTargets", "ui", "display", "notifications"]
    },
    "TimeBlock": {
      "title": "TimeBlock",
      "description": "A scheduled block of time in the timetable",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["task", "event", "break", "routine"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "color": { "type": "string" },
        "taskId": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["userId", "title", "startTime", "endTime"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A daily journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string", "enum": ["sad", "worried", "neutral", "happy", "ecstatic"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "wordCount": { "type": "integer" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "MotivationItem": {
      "title": "MotivationItem",
      "description": "A motivational resource saved by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["music", "quote", "link", "text"] },
        "content": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "content", "createdAt"]
    },
    "LifeSnapshot": {
      "title": "LifeSnapshot",
      "description": "A snapshot of life balance scores",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "values": { "type": "object" },
        "balanceScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "values", "balanceScore"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit tracking protocol",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["health", "learning", "creative", "work", "personal", "routine"] },
        "frequency": { "type": "string", "description": "e.g. 'daily' or 'Mon,Wed,Fri'" },
        "createdAt": { "type": "string", "format": "date-time" },
        "targetStreak": { "type": "integer" },
        "color": { "type": "string" },
        "isArchived": { "type": "boolean" }
      },
      "required": ["userId", "name", "category", "frequency", "createdAt"]
    },
    "HabitLog": {
      "title": "HabitLog",
      "description": "A completion log for a specific habit and date",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "habitId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "habitId", "date", "completed", "timestamp"]
    },
    "WeeklyReview": {
      "title": "WeeklyReview",
      "description": "A weekly debrief review entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "wentWell": { "type": "string" },
        "didntGo": { "type": "string" },
        "nextWeekFocus": { "type": "string" },
        "week": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "wentWell", "didntGo", "nextWeekFocus", "week", "createdAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/user_stats/{userId}": {
      "schema": "UserStats",
      "description": "User gamification statistics"
    },
    "/user_settings/{userId}": {
      "schema": "UserSettings",
      "description": "User preferences and settings"
    },
    "/time_blocks/{blockId}": {
      "schema": "TimeBlock",
      "description": "User timetable blocks"
    },
    "/journals/{journalId}": {
      "schema": "JournalEntry",
      "description": "User journal entries"
    },
    "/motivation_items/{itemId}": {
      "schema": "MotivationItem",
      "description": "User motivation repository"
    },
    "/life_snapshots/{snapshotId}": {
      "schema": "LifeSnapshot",
      "description": "User life balance history"
    },
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habit definitions"
    },
    "/habit_logs/{logId}": {
      "schema": "HabitLog",
      "description": "User habit completion logs"
    },
    "/weekly_reviews/{reviewId}": {
      "schema": "WeeklyReview",
      "description": "User weekly review entries"
    }
  }
}
