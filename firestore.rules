rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Collection
    match /test/{docId} {
      allow get: if true;
    }

    // Phase 3 Primitives
    function isSignedIn() { return request.auth != null; }
    // Mandated by instructions (enhanced for robust token parsing matches):
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com' ||
        request.auth.token.email == 'ved.websites@gmail.com'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // UserStats Validation
    function isValidUserStats(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.level is int && data.level >= 1 &&
             data.experience is int && data.experience >= 0 &&
             (!('coins' in data) || data.coins is int) &&
             (!('currentStreak' in data) || data.currentStreak is int) &&
             (!('pomodoroSessions' in data) || data.pomodoroSessions is int) &&
             (!('pomodoroToday' in data) || data.pomodoroToday is int) &&
             (!('dailyBriefing' in data) || (data.dailyBriefing.content is string && data.dailyBriefing.content.size() <= 10000)) &&
             (!('dailyChallenge' in data) || data.dailyChallenge is map) &&
             (!('unlockedPerks' in data) || data.unlockedPerks is list) &&
             (!('unlockedFeatures' in data) || data.unlockedFeatures is list) &&
             (!('unlockedAchievements' in data) || data.unlockedAchievements is list) &&
             (!('unlockedItems' in data) || data.unlockedItems is list) &&
             (!('activityLog' in data) || data.activityLog is list) &&
             (!('streakHistory' in data) || data.streakHistory is list) &&
             (!('adherenceHistory' in data) || data.adherenceHistory is map) &&
             (!('lifeSync' in data) || data.lifeSync is map) &&
             (!('lifeSyncCategories' in data) || data.lifeSyncCategories is list) &&
             (!('totalTasksCompleted' in data) || data.totalTasksCompleted is int) &&
             (!('lastActiveDate' in data) || data.lastActiveDate is string) &&
             (!('difficultyLevel' in data) || data.difficultyLevel in ['easy', 'normal', 'hard']) &&
             (!('totalWordsWritten' in data) || data.totalWordsWritten is int) &&
             (!('dailyWordsWritten' in data) || data.dailyWordsWritten is map) &&
             (!('peakSyncTime' in data) || data.peakSyncTime is string) &&
             (!('journalStreak' in data) || data.journalStreak is int) &&
             (!('lastJournalDate' in data) || data.lastJournalDate is string) &&
             (!('reflectionPromptsAnswered' in data) || data.reflectionPromptsAnswered is int) &&
             (!('scheduleMasteryLevel' in data) || data.scheduleMasteryLevel is int) &&
             (!('scheduledTasksCount' in data) || data.scheduledTasksCount is int) &&
             (!('punctualStreak' in data) || data.punctualStreak is int);
    }

    // Task Validation
    function isValidTask(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is string && data.createdAt.size() <= 100 &&
             data.category is string && data.category.size() <= 100 &&
             data.estimate is int &&
             (!('xpAwarded' in data) || data.xpAwarded is bool);
    }

    // JournalEntry Validation
    function isValidJournalEntry(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.content is string && data.content.size() <= 50000 &&
             data.mood in ['sad', 'worried', 'neutral', 'happy', 'ecstatic'] &&
             data.createdAt is string && data.createdAt.size() <= 100 &&
             (!('energyLevel' in data) || data.energyLevel in ['drained', 'low', 'neutral', 'high', 'peak']) &&
             (!('isReflection' in data) || data.isReflection is bool) &&
             (!('wordCount' in data) || data.wordCount is int) &&
             (!('promptUsed' in data) || data.promptUsed == null || (data.promptUsed is string && data.promptUsed.size() <= 1000)) &&
             (!('cognitiveSignature' in data) || data.cognitiveSignature == null || data.cognitiveSignature is map) &&
             (!('tags' in data) || data.tags is list);
    }

    // TimeBlock Validation
    function isValidTimeBlock(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.type in ['task', 'event', 'break', 'routine'] &&
             data.startTime is string && data.startTime.size() <= 100 &&
             data.endTime is string && data.endTime.size() <= 100;
    }

    // UserSettings Validation
    function isValidUserSettings(data) {
      return data.difficultyMultiplier is number &&
             data.goalTargets is map &&
             data.ui is map &&
             data.display is map &&
             data.notifications is map;
    }

    // MotivationItem Validation
    function isValidMotivationItem(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.type in ['music', 'quote', 'link', 'text'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidLifeSnapshot(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.date is string && data.date.size() <= 100 &&
             data.values is map &&
             data.balanceScore is number &&
             data.createdAt == request.time;
    }

    // Habit Validation
    function isValidHabit(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.frequency is string && data.frequency.size() <= 500 &&
             data.createdAt is string && data.createdAt.size() <= 100;
    }

    // HabitLog Validation
    function isValidHabitLog(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.habitId is string && data.habitId.size() <= 128 &&
             data.date is string && data.date.size() == 10 &&
             data.completed is bool &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             (!('xpAwarded' in data) || data.xpAwarded is bool) &&
             (!('uncompletedAt' in data) || (data.uncompletedAt is string && data.uncompletedAt.size() <= 100));
    }

    // WeeklyReview Validation
    function isValidWeeklyReview(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.wentWell is string && data.wentWell.size() <= 10000 &&
             data.didntGo is string && data.didntGo.size() <= 10000 &&
             data.nextWeekFocus is string && data.nextWeekFocus.size() <= 10000 &&
             data.week is string && data.week.size() <= 100 &&
             data.createdAt is string && data.createdAt.size() <= 100;
    }

    // --- Collections ---

    // UserStats: Identified by userId
    match /user_stats/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isVerified() && isValidUserStats(incoming()) && incoming().userId == userId;
      
      // Action-Based Updates
      allow update: if isOwner(userId) && isVerified() && isValidUserStats(incoming()) && (
        // Action: Daily Sync / Stats Update / XP Gain / Pomodoro
        (incoming().diff(existing()).affectedKeys().hasOnly(['currentStreak', 'lastActiveDate', 'experience', 'dailyChallenge', 'streakHistory', 'coins', 'level', 'totalTasksCompleted', 'activityLog', 'unlockedAchievements', 'unlockedItems', 'totalWordsWritten', 'journalStreak', 'lastJournalDate', 'reflectionPromptsAnswered', 'scheduleMasteryLevel', 'scheduledTasksCount', 'punctualStreak', 'adherenceHistory', 'unlockedFeatures', 'lifeSync', 'lifeSync.current', 'lifeSync.lastSaved', 'lifeSync.syncMode', 'dailyWordsWritten', 'peakSyncTime', 'pomodoroSessions', 'pomodoroToday', 'lifeSyncCategories'])) ||
        // Action: Perk Purchase
        (incoming().diff(existing()).affectedKeys().hasOnly(['coins', 'unlockedPerks'])) ||
        // Action: Daily Briefing Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['dailyBriefing'])) ||
        // Action: Feature Unlock (Single)
        (incoming().diff(existing()).affectedKeys().hasOnly(['unlockedFeatures']))
      )
    }

    // UserSettings: Identified by userId
    match /user_settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isVerified() && isValidUserSettings(incoming());
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidTask(incoming()) && isOwner(incoming().userId) && isValidId(taskId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidTask(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // Journals
    match /journals/{journalId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidJournalEntry(incoming()) && isOwner(incoming().userId) && isValidId(journalId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidJournalEntry(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // TimeBlocks
    match /time_blocks/{blockId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidTimeBlock(incoming()) && isOwner(incoming().userId) && isValidId(blockId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidTimeBlock(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // MotivationItems
    match /motivation_items/{itemId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidMotivationItem(incoming()) && isOwner(incoming().userId) && isValidId(itemId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidMotivationItem(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // LifeSnapshots
    match /life_snapshots/{snapshotId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidLifeSnapshot(incoming()) && isOwner(incoming().userId);
      allow update, delete: if false;
    }

    // Habits
    match /habits/{habitId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidHabit(incoming()) && isOwner(incoming().userId) && isValidId(habitId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidHabit(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // HabitLogs
    match /habit_logs/{logId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidHabitLog(incoming()) && isOwner(incoming().userId) && isValidId(logId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidHabitLog(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // WeeklyReviews
    match /weekly_reviews/{reviewId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && isValidWeeklyReview(incoming()) && isOwner(incoming().userId) && isValidId(reviewId);
      allow update: if isVerified() && isOwner(existing().userId) && isValidWeeklyReview(incoming()) && 
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && isOwner(existing().userId);
    }
  }
}
